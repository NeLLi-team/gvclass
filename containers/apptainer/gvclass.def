Bootstrap: docker
From: ghcr.io/prefix-dev/pixi:latest

%files
    LICENCE /opt/gvclass/LICENCE
    README.md /opt/gvclass/README.md
    config /opt/gvclass/config
    containers /opt/gvclass/containers
    example /opt/gvclass/example
    gvclass /opt/gvclass/gvclass
    gvclass-a /opt/gvclass/gvclass-a
    images /opt/gvclass/images
    pixi.lock /opt/gvclass/pixi.lock
    pixi.toml /opt/gvclass/pixi.toml
    pyproject.toml /opt/gvclass/pyproject.toml
    src /opt/gvclass/src

%environment
    export PATH=/usr/local/bin:/opt/gvclass/.pixi/envs/default/bin:$PATH
    export PYTHONPATH=/opt/gvclass:$PYTHONPATH
    export GVCLASS_RESOURCE_CACHE="${GVCLASS_RESOURCE_CACHE:-/tmp/gvclass-resource-cache}"

%post
    # Install system dependencies
    # The pixi base image is based on Debian/Ubuntu
    apt-get update && apt-get install -y \
        build-essential \
        git \
        libgomp1 \
        wget \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*
    
    cd /opt/gvclass
    
    # Install the environment using pixi
    pixi install
    
    # Download the database if it doesn't exist
    if [ ! -d "/opt/gvclass/resources/database" ] || [ ! -f "/opt/gvclass/resources/hmm/combined.hmm" ]; then
        echo "Downloading GVClass database..."
        pixi run setup-db || {
            echo "Failed to download database during build"
            exit 1
        }
    fi

    # Fix permissions on database files to make them readable
    chmod -R a+rX /opt/gvclass/resources/ 2>/dev/null || true
    chmod -R 755 /opt/gvclass/resources/database/ 2>/dev/null || true
    chmod 644 /opt/gvclass/resources/labels.tsv /opt/gvclass/resources/parquet/*.parquet /opt/gvclass/resources/parquet/labels/*.parquet 2>/dev/null || true
    chmod 644 /opt/gvclass/resources/markers/*.tsv /opt/gvclass/resources/markers/*.tab 2>/dev/null || true
    chmod 644 /opt/gvclass/resources/completeness/*.tsv /opt/gvclass/resources/completeness/*.json 2>/dev/null || true
    chmod 644 /opt/gvclass/resources/contamination/*.joblib /opt/gvclass/resources/contamination/*.yaml 2>/dev/null || true
    
    # Clean up pixi cache and staging directory
    pixi clean cache -y || true
    rm -rf /opt/gvclass/.pixi/cache 2>/dev/null || true
    rm -rf /opt/gvclass/__pycache__ 2>/dev/null || true
    find /opt/gvclass -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true

    # Make the application tree usable by non-root Apptainer/Singularity users.
    chmod -R a+rX /opt/gvclass
    chmod a+rx /opt/gvclass/gvclass /opt/gvclass/gvclass-a
    ln -sf /opt/gvclass/gvclass /usr/local/bin/gvclass
%runscript
    # Check if first argument looks like a path
    if [ -z "$1" ] || [ "$(echo "$1" | cut -c1)" = "-" ]; then
        echo "Error: Please provide input directory as first argument"
        echo "Usage: singularity run -B /your/data:/data gvclass.sif /data/input_dir [options]"
        exit 1
    fi
    
    cd /opt/gvclass
    mkdir -p "${GVCLASS_RESOURCE_CACHE:-/tmp/gvclass-resource-cache}" 2>/dev/null || true
    exec ./gvclass "$@"

%labels
    Author fschulz
    Version v2.0-dev
    Description GVClass - Giant Virus Classification Pipeline with Pixi
    Database v2.0.0
    ResourceCache /tmp/gvclass-resource-cache

%help
    GVClass Pipeline v2.0-dev
    
    IMPORTANT: Input data must be bind-mounted!
    
    Usage:
        singularity run -B /path/to/data:/data gvclass.sif /data/query_dir [options]
    
    Examples:
        # Run on example directory
        singularity run -B $(pwd):/data -B $HOME/.cache/gvclass/resource-cache/v2.0-dev:/tmp/gvclass-resource-cache gvclass.sif /data/example -t 8
        
        # Run on any query directory
        singularity run -B /home/user/genomes:/input gvclass.sif /input/my_queries -t 32
        
        # With custom output directory
        singularity run -B /path/to/data:/data gvclass.sif /data/input -o /data/output -t 16
    
    The pipeline will process ALL .fna and .faa files found in the input directory.
    
    NOTE: The resources database is included in the container at /opt/gvclass/resources.
    NOTE: Compact Parquet resources materialize needed TSV/FASTA views under
    GVCLASS_RESOURCE_CACHE. Bind a host directory to /tmp/gvclass-resource-cache
    for a persistent warm cache across runs.
